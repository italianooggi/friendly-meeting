# .gitignore for Agente-CV

# ============================================================
#  PRIVATE — Candidate Data & AI Metadata
# ============================================================
# REAL candidate data (regardless of folder name)
context/candidates/
output/
# Keep directory structure via .gitkeep
!output/.gitkeep
!templates/.gitkeep

# AI Assistant Metadata (Antigravity/Engram/Cursor/Windsurf)
# These folders may contain full conversation history & PII
.brain/
.gemini/
.agent/
.agents/brain/

# ============================================================
#  OS & IDE
# ============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
.project
.settings/

# ============================================================
#  Runtime & Secrets
# ============================================================
node_modules/
__pycache__/
*.pyc
.env*
*.tmp
*.bak

# Common secret-holding patterns
*.pem
*.key
secrets.*
config.local.*
