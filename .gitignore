# .gitignore for Agente-CV

# ============================================================
#  PRIVATE — Never commit candidate personal data
# ============================================================
# Real candidate Brains live in context/candidates/<name>/
# They are NEVER committed to git. Templates only go to GitHub.
context/candidates/

# ============================================================
#  Generated output files (pipeline artifacts)
# ============================================================
output/job_analysis.md
output/match_report.md
output/cv_draft.md
output/validation_report.md
output/gap_analysis.md
output/quality_report.md
output/archive/

# ============================================================
#  OS & IDE
# ============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/

# ============================================================
#  Runtime & dependencies
# ============================================================
node_modules/
__pycache__/
*.pyc
.env
*.tmp
*.bak
